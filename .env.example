# Required runtime settings / 必填运行配置
AGENTBRIDGE_ENABLED_PLATFORMS=lark
AGENTBRIDGE_DB_PATH=./agentbridge.db
AGENTBRIDGE_ALLOWED_CWDS=E:/your/project,E:/another/project
AGENTBRIDGE_DEFAULT_AGENT=claude
AGENTBRIDGE_DEFAULT_TIMEOUT_MS=1800000

# Optional proxy settings / 可选代理配置
# Leave these empty if your machine can access Slack / Feishu / model providers directly.
# 如果你的机器可以直接访问 Slack / 飞书 / 模型服务，这两项留空即可。
# Fill them only when your local environment requires an HTTP(S) proxy.
# 仅当你的本地环境必须通过 HTTP(S) 代理联网时才填写。
AGENTBRIDGE_HTTP_PROXY=
AGENTBRIDGE_HTTPS_PROXY=

# Claude Code / Claude Code 配置
AGENTBRIDGE_CLAUDE_COMMAND=E:/nodejs/claude.cmd
AGENTBRIDGE_CLAUDE_ARGS=-p --output-format json --permission-mode bypassPermissions
AGENTBRIDGE_CLAUDE_RESUME_ARGS=-p --output-format json --permission-mode bypassPermissions -r {sessionId}
AGENTBRIDGE_CLAUDE_OUTPUT_MODE=claude_json

# OpenAI Codex CLI / OpenAI Codex CLI 配置
AGENTBRIDGE_CODEX_COMMAND=node
AGENTBRIDGE_CODEX_ARGS=node_modules/@openai/codex/bin/codex.js exec --dangerously-bypass-approvals-and-sandbox --skip-git-repo-check -
AGENTBRIDGE_CODEX_RESUME_ARGS=node_modules/@openai/codex/bin/codex.js exec resume {sessionId} --dangerously-bypass-approvals-and-sandbox --skip-git-repo-check -
AGENTBRIDGE_CODEX_OUTPUT_MODE=codex_text

# Slack / Slack 配置
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_APP_TOKEN=xapp-your-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_ALLOWED_USER_ID=U0123456789

# Feishu / Lark / 飞书配置
LARK_APP_ID=cli_xxxxx
LARK_APP_SECRET=your-app-secret
LARK_ALLOWED_USER_ID=ou_xxxxx

# Optional for encrypted event payloads / 加密事件载荷时可选
# Long connection mode can leave these empty.
# 长连接模式下这两项可以留空。
LARK_ENCRYPT_KEY=
LARK_VERIFICATION_TOKEN=
